<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene width="598.5">
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox fx:id="mainContainer">
        <children>
          <!-- URL Section at the top -->
          <VBox alignment="CENTER" fx:id="urlSection">
            <children>
              <Label fx:id="urlLabel" text="Label" wrapText="true">
                <VBox.margin>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
                </VBox.margin>
              </Label>
              <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL">
                <VBox.margin>
                  <Insets bottom="10.0" />
                </VBox.margin>
              </Button>
            </children>
            <padding>
              <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
            </padding>
          </VBox>

          <!-- Commands Table below -->
          <TableView fx:id="commandTable" fixedCellSize="-1" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
              <TableColumn fx:id="commandColumn" prefWidth="70.0" text="Word" />
              <TableColumn fx:id="usageColumn" prefWidth="500.0" text="Usage" />
            </columns>
            <VBox.margin>
              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </VBox.margin>
          </TableView>
        </children>
      </VBox>
    </Scene>
  </scene>
</fx:root>
